[package]
name = "ax_slab_allocator"
version = "0.4.0"
edition = "2021"
authors = [
    "Robert Węcławski <r.weclawski@gmail.com>",
    "Yiren Zhang <zyr_ms@outlook.com>",
]
license = "MIT"
repository = "https://github.com/arceos-org/ax_slab_allocator"

description = "Slab allocator for `no_std` systems. Uses multiple slabs with blocks of different sizes and a linked list for blocks larger than 4096 bytes"
keywords = ["slab", "allocator", "no_std", "heap", "kernel"]

[dependencies]
buddy_system_allocator = { version = "0.12", default-features = false }
